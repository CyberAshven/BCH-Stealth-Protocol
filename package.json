{
  "name": "bch-stealth-wallet",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "relay": "node relay.js",
    "relay:joiner-only": "node relay.js --joiner-only",
    "relay:indexer-only": "node relay.js --indexer-only",
    "indexer": "node pubkey-indexer.js --mode serve",
    "scan": "node pubkey-indexer.js --mode scan",
    "desktop:build:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --x64 --arm64",
    "desktop:build:linux": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --linux AppImage --x64 --arm64",
    "desktop:build:mac": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip --x64 --arm64",
    "android:build": "node scripts/build-android.mjs"
  },
  "build": {
    "appId": "com.zeroprotocol.bchstealthwallet",
    "productName": "BCH Stealth Wallet",
    "directories": { "output": "dist/desktop" },
    "files": ["desktop/**/*", "landing/**/*", "package.json"],
    "extraMetadata": { "main": "desktop/main.js" },
    "win": { "target": [{ "target": "nsis", "arch": ["x64", "arm64"] }] },
    "linux": { "target": [{ "target": "AppImage", "arch": ["x64", "arm64"] }], "category": "Utility" },
    "mac": { "target": [{ "target": "zip", "arch": ["x64", "arm64"] }] }
  },
  "devDependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/cli": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "cross-env": "^7.0.3",
    "electron": "^33.3.2",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@noble/ciphers": "^1.2.1",
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.1",
    "esbuild": "^0.27.4",
    "monero-ts": "^0.11.8",
    "ws": "^8.19.0"
  }
}
